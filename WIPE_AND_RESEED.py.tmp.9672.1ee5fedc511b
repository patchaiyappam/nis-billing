def main():
    base    = Path.home() / "Documents" / "NEW_INDIAN_STEEL"
    db_path = base / "billing.db"
    backups = base / "backups"
    backups.mkdir(parents=True, exist_ok=True)

    if not db_path.exists():
        print(f"ERROR: live DB not found at {db_path}")
        return 1

    # ---- Initialize schema (in case migrations haven't run yet) ----
    # Touch config and run init + migrations so the DB is up to date.
    import config
    config.DB_PATH = str(db_path)
    from database import init_database
    from migrations import run_migrations
    init_database()
    run_migrations()

    # ---- Confirmation prompt ----
    print()
    print("=" * 70)
    print("  WIPE AND RESEED — local SQLite database")
    print("=" * 70)
    print(f"  DB path: {db_path}")
    print(f"  About to delete ALL invoices, invoice_items, payments,")
    print(f"  pending_syncs, background_tasks, customers, products,")
    print(f"  then reseed with {len(CUSTOMERS)} customers and {len(PRODUCTS)} products.")
    print()
    ans = input("  Type RESEED to continue (anything else cancels): ").strip()
    if ans != "RESEED":
        print("  Cancelled. Nothing was changed.")
        return 0

    # ---- Backup ----
    ts = datetime.now().strftime("%Y%m%d_%H%M%S")
    backup_path = backups / f"billing.db.backup-pre-reseed-{ts}"
    shutil.copy2(db_path, backup_path)
    print(f"\n  Backup written to: {backup_path}")

    # Also copy WAL/SHM if present
    for ext in ("-wal", "-shm"):
        side = db_path.with_suffix(db_path.suffix + ext)
        if side.exists():
            shutil.copy2(side, backup_path.with_suffix(backup_path.suffix + ext))

    # ---- Wipe and reseed in one transaction ----
    conn = sqlite3.connect(str(db_path), timeout=10)
    conn.row_factory = sqlite3.Row
    try:
        conn.execute("PRAGMA foreign_keys = OFF")
        c = conn.cursor()

        for tbl in (
            "invoice_items",
            "invoices",
            "payments",
            "pending_syncs",
            "background_tasks",
            "customers",
            "products",
        ):
            try:
                n = c.execute(f"SELECT COUNT(*) FROM {tbl}").fetchone()[0]
            except sqlite3.OperationalError:
                n = "n/a"
            c.execute(f"DELETE FROM {tbl}")
            print(f"  WIPED  {tbl:18s} (was {n} rows)")

        # Reset auto-increment counters where present
        c.execute(
            "DELETE FROM sqlite_sequence WHERE name IN "
            "('invoice_items','invoices','payments','pending_syncs',"
            "'background_tasks','customers','products')"
        )

        # Insert customers
        for name, phone, ob in CUSTOMERS:
            c.execute(
                "INSERT INTO customers (name, phone, opening_balance, total_due, address) "
                "VALUES (?, ?, ?, ?, ?)",
                (name, phone, float(ob), float(ob), ""),
            )
        print(f"  SEEDED {len(CUSTOMERS)} customers")

        # Insert Cr carry-over as a payment for Jj Traders
        # (negates the 0 opening balance to make total_due correctly negative)
        now = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        for cr in CR_CARRYOVER:
            c.execute(
                "INSERT INTO payments (customer_phone, amount, date) "
                "VALUES (?, ?, ?)",
                (cr["phone"], float(cr["amount"]), now),
            )
            # total_due also needs the negative adjustment
            c.execute(
                "UPDATE customers SET total_due = total_due - ? WHERE phone = ?",
                (float(cr["amount"]), cr["phone"]),
            )
            print(f"  CR carry-over: {cr['phone']} -₹{cr['amount']:.2f}  ({cr['note']})")

        # Insert products in source order so IDs map to the printed list
        for name, price in PRODUCTS:
            c.execute(
                "INSERT INTO products (name, price) VALUES (?, ?)",
                (name, float(price)),
            )
        print(f"  SEEDED {len(PRODUCTS)} products")

        conn.commit()
    except Exception as e:
        conn.rollback()
        print(f"\n  ERROR during reseed: {e}")
        print(f"  Rolled back. Restore from backup if needed:")
        print(f"    copy \"{backup_path}\" \"{db_path}\"")
        return 2
    finally:
        conn.close()

    # ---- Summary ----
    conn = sqlite3.connect(str(db_path))
    conn.row_factory = sqlite3.Row
    print()
    print("=" * 70)
    print("  POST-RESEED SUMMARY")
    print("=" * 70)
    n_cust = conn.execute("SELECT COUNT(*) FROM customers").fetchone()[0]
    n_prod = conn.execute("SELECT COUNT(*) FROM products").fetchone()[0]
    n_inv  = conn.execute("SELECT COUNT(*) FROM invoices").fetchone()[0]
    n_pay  = conn.execute("SELECT COUNT(*) FROM payments").fetchone()[0]
    tot_due = conn.execute("SELECT COALESCE(SUM(total_due),0) FROM customers").fetchone()[0]
    print(f"  customers: {n_cust}")
    print(f"  products : {n_prod}")
    print(f"  invoices : {n_inv}  (should be 0)")
    print(f"  payments : {n_pay}  (1 = Jj Traders Cr carry-over)")
    print(f"  total of customer total_due: Rs {tot_due:,.2f}")
    print(f"  expected from Khatabook    : Rs 971,924.00  (Dr 1,000,774 - Cr 28,850)")
    conn.close()

    print()
    print("  Done. Start the app (Shop Mode or Admin Mode) - on first launch")
    print("  the background sync will push the fresh data to Supabase.")
    return 0


if __name__ == "__main__":
    sys.exit(main())
